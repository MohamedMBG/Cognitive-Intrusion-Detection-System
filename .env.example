# ── Capture ────────────────────────────────────────────────────────────────────
CAPTURE_INTERFACE=         # leave empty for auto-detect
PACKET_WORKERS=4
PACKET_QUEUE_SIZE=20000

# ── Detection ──────────────────────────────────────────────────────────────────
FLOW_TIMEOUT=120
MAX_ACTIVE_FLOWS=50000
MIN_PACKETS_FOR_ML=10
LARGE_PAYLOAD_BYTES=10000
MAX_PAYLOAD_SAMPLES=50     # max payload samples stored per flow
PAYLOAD_SAMPLE_BYTES=4096  # max bytes kept per payload sample

# ── Engine weights (must sum to 1.0) ──────────────────────────────────────────
WEIGHT_SUPERVISED=0.40
WEIGHT_IFOREST=0.30
WEIGHT_LSTM=0.20
WEIGHT_RULES=0.10
ENSEMBLE_THRESHOLD=0.55

# ── Per-attack-type weight overrides (Phase 4) ────────────────────────────────
# JSON: {"DoS": {"supervised": 0.6, "rules": 0.2}}
ATTACK_TYPE_WEIGHTS={}
CALIBRATION_TEMPERATURE=1.0   # >1 = softer scores, <1 = sharper

# ── Model paths ────────────────────────────────────────────────────────────────
MODELS_DIR=models
RF_MODEL_FILE=rf_model.joblib
IF_MODEL_FILE=isolation_forest.joblib
IF_SCALER_FILE=if_scaler.joblib
LSTM_MODEL_FILE=lstm_autoencoder.pt
LSTM_CONFIG_FILE=lstm_config.json

# ── MLflow (Phase 5) ──────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=       # empty = disabled; e.g. http://localhost:5000
MLFLOW_REGISTRY_NAME=cnds

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./cnds.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cnds

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=                   # leave empty to disable API-key auth
CORS_ORIGINS=              # comma-separated origins; empty defaults to http://localhost:3000

# ── JWT Auth (Phase 7) ────────────────────────────────────────────────────────
JWT_SECRET=                # leave empty to disable JWT auth
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Observability (Phase 7) ───────────────────────────────────────────────────
PROMETHEUS_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=   # e.g. http://localhost:4317
